# ============================================================
#  AI Agent Starter Kit — Contoh Config
#  Copy file ini ke .env dan isi sesuai kebutuhan
#  Jangan share file .env ke siapapun!
# ============================================================

# ─── TELEGRAM ────────────────────────────────────────────────
# Dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dari @userinfobot di Telegram
TELEGRAM_OWNER_ID=123456789

# User ID yang boleh akses bot (pisah koma kalau lebih dari 1)
TELEGRAM_ALLOWED_USERS=123456789

# ─── 9ROUTER ─────────────────────────────────────────────────
# API Key dari dashboard 9Router (Endpoint → New Key)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx-xxxxxxxx

# Base URL 9Router
# Kalau 9Router di VPS yang sama:
OPENAI_BASE_URL=http://localhost:20128/v1
# Kalau 9Router di VPS lain:
# OPENAI_BASE_URL=http://43.156.130.205:20128/v1

# ─── NVIDIA NIM ──────────────────────────────────────────────
# Daftar gratis di: https://build.nvidia.com
# Klik avatar → Get API Key → Generate Key
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── MIMO XIAOMI ─────────────────────────────────────────────
# Daftar di: https://platform.xiaomimimo.com
# Token Plan Lite: 4.1B credits/bulan
MIMO_API_KEY=tp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GROQ ────────────────────────────────────────────────────
# Daftar gratis di: https://console.groq.com
# Llama 3.3 70B: 6,000 req/hari gratis
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── PIONEER AI ──────────────────────────────────────────────
# Daftar di: https://pioneer.ai
PIONEER_API_KEY=pio_sk_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx_xxx_xxxx

# ─── CATATAN ─────────────────────────────────────────────────
# - Minimal isi 1 LLM provider
# - OPENAI_API_KEY wajib diisi (dari 9Router)
# - File ini jangan di-commit ke git!
# - Simpan backup di tempat yang aman
